# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Right-click a user in Discord (with Developer Mode on) → Copy User ID
TARGET_USER_ID=

# Right-click the channel in Discord → Copy Channel ID
CHANNEL_ID=

# Time to send the daily reminder (UTC, 24-hour clock)
REMINDER_HOUR=9
REMINDER_MINUTE=0

# The message to send (the user mention is added automatically)
REMINDER_MESSAGE=Ne pozabi napisati na magistrsko! 🎓
